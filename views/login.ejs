<div class="form-container">
  <h2>Вхід</h2>
  <form action="/auth/login" method="POST">
    <input
      type="text"
      name="contacts"
      placeholder="Телефон або Email"
      required
    />
    <input type="password" name="password" placeholder="Пароль" required />

    <button type="submit" style="background: #007bff">Увійти</button>
  </form>
  <div class="switch">
    Немає акаунту? <a href="login/register">Зареєструватися</a>
  </div>
</div>
